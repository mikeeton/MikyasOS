generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum OrganisationRoleType {
  OWNER
  ADMIN
  MEMBER
  GUEST
  CUSTOM
}

enum CompanyStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  CUSTOMER
  PARTNER
  SUPPLIER
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum OpportunityStage {
  DISCOVERY
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

enum CustomerActivityType {
  COMPANY_CREATED
  COMPANY_UPDATED
  CONTACT_ADDED
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_CONVERTED
  OPPORTUNITY_CREATED
  OPPORTUNITY_UPDATED
  OPPORTUNITY_WON
  OPPORTUNITY_LOST
  NOTE_ADDED
  FILE_UPLOADED
  TAG_CHANGED
  CUSTOMER_EDITED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MilestoneStatus {
  PLANNED
  ACTIVE
  COMPLETED
  MISSED
}

enum ProjectActivityType {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_ARCHIVED
  PROJECT_RESTORED
  TASK_CREATED
  TASK_UPDATED
  TASK_MOVED
  TASK_ASSIGNED
  TASK_COMPLETED
  COMMENT_ADDED
  FILE_UPLOADED
  MILESTONE_UPDATED
  STATUS_CHANGED
  LABEL_CHANGED
  TIME_TRACKED
}

enum DocumentType {
  PDF
  DOCX
  XLSX
  CSV
  IMAGE
  TEXT
  MARKDOWN
  OTHER
}

enum DocumentStatus {
  ACTIVE
  PROCESSING
  ARCHIVED
  DELETED
}

enum DocumentVisibility {
  PRIVATE
  ORGANISATION
  RESTRICTED
}

enum DocumentPermissionLevel {
  VIEW
  COMMENT
  EDIT
  MANAGE
  OWNER
}

enum DocumentActivityAction {
  DOCUMENT_UPLOADED
  DOCUMENT_VIEWED
  DOCUMENT_DOWNLOADED
  DOCUMENT_EDITED
  DOCUMENT_RENAMED
  DOCUMENT_MOVED
  DOCUMENT_DELETED
  DOCUMENT_RESTORED
  VERSION_UPLOADED
  VERSION_RESTORED
  PERMISSION_CHANGED
  FOLDER_CREATED
  FOLDER_RENAMED
  FOLDER_MOVED
  FOLDER_DELETED
  TAG_ADDED
  TAG_REMOVED
  DOCUMENT_LINKED
  DOCUMENT_UNLINKED
}

enum DocumentLinkEntityType {
  COMPANY
  CONTACT
  PROJECT
  TASK
  INVOICE
  MEETING
  AUTOMATION
}

enum ConversationType {
  DIRECT
  GROUP
  CHANNEL
  ANNOUNCEMENT
}

enum ConversationVisibility {
  PUBLIC
  PRIVATE
  DEPARTMENT
  PROJECT
  COMPANY_WIDE
}

enum ConversationMemberRole {
  OWNER
  ADMIN
  MEMBER
  GUEST
}

enum MessageStatus {
  ACTIVE
  EDITED
  DELETED
}

enum MessageActivityAction {
  SENT
  EDITED
  DELETED
  REACTION_ADDED
  REACTION_REMOVED
  READ
  ATTACHMENT_ADDED
  THREAD_STARTED
}

enum AnnouncementPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum MeetingStatus {
  DRAFT
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum MeetingParticipantStatus {
  INVITED
  ACCEPTED
  DECLINED
  TENTATIVE
}

enum PresenceStatus {
  ONLINE
  AWAY
  BUSY
  OFFLINE
  IN_MEETING
  WORKING_ON_PROJECT
}

enum WorkflowStatus {
  DRAFT
  ACTIVE
  PAUSED
  ARCHIVED
}

enum WorkflowTriggerType {
  CUSTOMER_CREATED
  LEAD_WON
  PROJECT_CREATED
  TASK_COMPLETED
  DOCUMENT_UPLOADED
  MEETING_ENDED
  INVOICE_PAID
  CALENDAR_EVENT
  WEBHOOK_RECEIVED
  MANUAL
  SCHEDULED
}

enum WorkflowConditionOperator {
  EQUALS
  CONTAINS
  GREATER_THAN
  LESS_THAN
  DATE
  USER
  ROLE
  DEPARTMENT
  PROJECT_STATUS
  CRM_STATUS
  DOCUMENT_TAG
  CUSTOM_EXPRESSION
}

enum WorkflowActionType {
  CREATE_TASK
  ASSIGN_TASK
  CREATE_PROJECT
  CREATE_COMPANY
  CREATE_CONTACT
  SEND_NOTIFICATION
  SEND_EMAIL
  GENERATE_AI_SUMMARY
  CREATE_MEETING
  CREATE_CALENDAR_EVENT
  MOVE_CRM_STAGE
  UPDATE_RECORD
  CREATE_DOCUMENT
  RUN_WEBHOOK
  WAIT
  APPROVAL
}

enum WorkflowExecutionStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELLED
  WAITING_APPROVAL
}

enum WorkflowScheduleType {
  ONCE
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  CRON
}

enum WorkflowApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum WorkflowLogSeverity {
  DEBUG
  INFO
  WARN
  ERROR
}

enum FinanceDocumentStatus {
  DRAFT
  SENT
  APPROVED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
  CANCELLED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

enum PaymentMethod {
  BANK_TRANSFER
  CARD
  CASH
  STRIPE
  PAYPAL
  MANUAL
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum RecurringBillingFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  ADJUSTMENT
}

enum AccountType {
  BANK
  CASH
  CREDIT_CARD
  REVENUE
  EXPENSE
  ASSET
  LIABILITY
  EQUITY
}

enum FinancialReportType {
  PROFIT_AND_LOSS
  REVENUE
  EXPENSES
  CASH_FLOW
  TAX_SUMMARY
  CUSTOMER_REVENUE
  PROJECT_PROFITABILITY
  DEPARTMENT_SPEND
}

enum CashFlowDirection {
  INFLOW
  OUTFLOW
}

model User {
  id                   String               @id @default(uuid()) @db.Uuid
  email                String               @unique
  name                 String
  passwordHash         String
  status               UserStatus           @default(ACTIVE)
  activeOrganisationId String?              @db.Uuid
  lastLoginAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  memberships          OrganisationMember[]
  ownedOrganisations   Organisation[]       @relation("OrganisationOwner")
  invitationsSent      Invitation[]         @relation("InvitationInviter")
  invitationsAccepted  Invitation[]         @relation("InvitationAcceptedBy")
  sessions             Session[]
  refreshTokens        RefreshToken[]
  auditLogs            AuditLog[]
  assignedLeads        Lead[]               @relation("LeadAssignee")
  ownedOpportunities   Opportunity[]        @relation("OpportunityOwner")
  customerNotes        CustomerNote[]       @relation("CustomerNoteAuthor")
  customerFiles        CustomerFile[]       @relation("CustomerFileUploader")
  customerActivities   CustomerActivity[]   @relation("CustomerActivityActor")
  ownedProjects        Project[]            @relation("ProjectOwner")
  assignedTasks        Task[]               @relation("TaskAssignee")
  reportedTasks        Task[]               @relation("TaskReporter")
  projectComments      ProjectComment[]     @relation("ProjectCommentAuthor")
  projectFiles         ProjectFile[]        @relation("ProjectFileUploader")
  timeEntries          TimeEntry[]          @relation("TimeEntryUser")
  projectActivities    ProjectActivity[]    @relation("ProjectActivityActor")
  ownedFolders         Folder[]             @relation("FolderOwner")
  ownedDocuments       Document[]           @relation("DocumentOwner")
  documentVersions     DocumentVersion[]    @relation("DocumentVersionUploader")
  documentPermissions  DocumentPermission[] @relation("DocumentPermissionUser")
  documentActivities   DocumentActivity[]   @relation("DocumentActivityActor")
  documentShares       DocumentShare[]      @relation("DocumentShareCreator")
  createdConversations Conversation[]       @relation("ConversationCreator")
  conversationMembers  ConversationMember[]
  messages             Message[]            @relation("MessageAuthor")
  messageAttachments   MessageAttachment[]  @relation("MessageAttachmentUploader")
  messageReactions     MessageReaction[]
  messageReadReceipts  MessageReadReceipt[]
  threads              Thread[]             @relation("ThreadCreator")
  announcements        Announcement[]       @relation("AnnouncementAuthor")
  meetings             Meeting[]            @relation("MeetingOrganizer")
  meetingParticipants  MeetingParticipant[]
  meetingNotes         MeetingNote[]        @relation("MeetingNoteAuthor")
  messageActivities    MessageActivity[]    @relation("MessageActivityActor")
  notificationPrefs    NotificationPreference[]
  workflows            Workflow[]             @relation("WorkflowCreator")
  workflowExecutions   WorkflowExecution[]    @relation("WorkflowExecutionActor")
  workflowApprovals    WorkflowApproval[]     @relation("WorkflowApprovalRequester")
  workflowApprovalsReviewed WorkflowApproval[] @relation("WorkflowApprovalReviewer")
  workflowAudits       WorkflowAudit[]        @relation("WorkflowAuditActor")
  financeAudits        FinanceAudit[]         @relation("FinanceAuditActor")
  activeOrganisation   Organisation?        @relation("ActiveOrganisation", fields: [activeOrganisationId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([activeOrganisationId])
  @@index([deletedAt])
}

model Organisation {
  id                  String               @id @default(uuid()) @db.Uuid
  name                String
  slug                String               @unique
  industry            String?
  companySize         String?
  country             String?
  timezone            String?
  currency            String?
  ownerId             String               @db.Uuid
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  owner               User                 @relation("OrganisationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  activeUsers         User[]               @relation("ActiveOrganisation")
  members             OrganisationMember[]
  roles               Role[]
  invitations         Invitation[]
  sessions            Session[]
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]
  companies           Company[]
  contacts            Contact[]
  leads               Lead[]
  opportunities       Opportunity[]
  customerNotes       CustomerNote[]
  customerFiles       CustomerFile[]
  customerTags        CustomerTag[]
  activities          CustomerActivity[]
  projects            Project[]
  tasks               Task[]
  projectLabels       ProjectLabel[]
  projectFiles        ProjectFile[]
  timeEntries         TimeEntry[]
  projectBoards       ProjectBoard[]
  projectActivities   ProjectActivity[]
  projectComments     ProjectComment[]
  folders             Folder[]
  documents           Document[]
  documentVersions    DocumentVersion[]
  documentPermissions DocumentPermission[]
  documentActivities  DocumentActivity[]
  documentTags        DocumentTag[]
  documentLinks       DocumentLink[]
  documentShares      DocumentShare[]
  conversations       Conversation[]
  conversationMembers ConversationMember[]
  messages            Message[]
  messageAttachments  MessageAttachment[]
  messageReactions    MessageReaction[]
  messageReadReceipts MessageReadReceipt[]
  threads             Thread[]
  announcements       Announcement[]
  meetings            Meeting[]
  meetingParticipants MeetingParticipant[]
  meetingNotes        MeetingNote[]
  meetingRecordings   MeetingRecording[]
  messageActivities   MessageActivity[]
  notificationPrefs   NotificationPreference[]
  workflows           Workflow[]
  workflowVersions    WorkflowVersion[]
  workflowExecutions  WorkflowExecution[]
  workflowTriggers    WorkflowTrigger[]
  workflowConditions  WorkflowCondition[]
  workflowActions     WorkflowAction[]
  workflowVariables   WorkflowVariable[]
  workflowTemplates   WorkflowTemplate[]
  workflowSchedules   WorkflowSchedule[]
  workflowApprovals   WorkflowApproval[]
  workflowLogs        WorkflowLog[]
  workflowAudits      WorkflowAudit[]
  workflowErrors      WorkflowError[]
  invoices            Invoice[]
  invoiceItems        InvoiceItem[]
  quotes              Quote[]
  quoteItems          QuoteItem[]
  expenses            Expense[]
  expenseCategories   ExpenseCategory[]
  payments            Payment[]
  purchaseOrders      PurchaseOrder[]
  purchaseOrderItems  PurchaseOrderItem[]
  recurringInvoices   RecurringInvoice[]
  subscriptions       Subscription[]
  budgets             Budget[]
  transactions        Transaction[]
  accounts            Account[]
  taxRates            TaxRate[]
  currencies          Currency[]
  financialReports    FinancialReport[]
  cashFlowEntries     CashFlowEntry[]
  journalEntries      JournalEntry[]
  financeAudits       FinanceAudit[]

  @@index([ownerId])
  @@index([deletedAt])
}

model OrganisationMember {
  id             String               @id @default(uuid()) @db.Uuid
  organisationId String               @db.Uuid
  userId         String               @db.Uuid
  roleId         String               @db.Uuid
  roleType       OrganisationRoleType @default(MEMBER)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  organisation   Organisation         @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role                 @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([organisationId, userId])
  @@index([userId])
  @@index([roleId])
  @@index([organisationId, roleType])
  @@index([deletedAt])
}

model Role {
  id                  String               @id @default(uuid()) @db.Uuid
  organisationId      String               @db.Uuid
  name                String
  description         String?
  type                OrganisationRoleType @default(CUSTOM)
  isSystem            Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  deletedAt           DateTime?
  organisation        Organisation         @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  members             OrganisationMember[]
  rolePermissions     RolePermission[]
  invitations         Invitation[]
  documentPermissions DocumentPermission[]

  @@unique([organisationId, name])
  @@index([organisationId, type])
  @@index([deletedAt])
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  key             String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organisationId String           @db.Uuid
  email          String
  roleId         String           @db.Uuid
  tokenHash      String           @unique
  status         InvitationStatus @default(PENDING)
  invitedById    String           @db.Uuid
  acceptedById   String?          @db.Uuid
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  revokedAt      DateTime?
  organisation   Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  role           Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy      User             @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Restrict)
  acceptedBy     User?            @relation("InvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@unique([organisationId, email, status])
  @@index([organisationId])
  @@index([email])
  @@index([expiresAt])
}

model Session {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @db.Uuid
  organisationId String?        @db.Uuid
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  expiresAt      DateTime
  revokedAt      DateTime?
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation   Organisation?  @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  refreshTokens  RefreshToken[]

  @@index([userId])
  @@index([organisationId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model RefreshToken {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid
  organisationId String?       @db.Uuid
  sessionId      String        @db.Uuid
  tokenHash      String        @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  expiresAt      DateTime
  revokedAt      DateTime?
  replacedById   String?       @unique @db.Uuid
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation   Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  session        Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  replacedBy     RefreshToken? @relation("RefreshTokenRotation", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces       RefreshToken? @relation("RefreshTokenRotation")

  @@index([userId])
  @@index([sessionId])
  @@index([organisationId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AuditLog {
  id             String        @id @default(uuid()) @db.Uuid
  organisationId String?       @db.Uuid
  actorUserId    String?       @db.Uuid
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  organisation   Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  actorUser      User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organisationId, createdAt])
  @@index([actorUserId])
  @@index([action])
}

model Company {
  id             String             @id @default(uuid()) @db.Uuid
  organisationId String             @db.Uuid
  name           String
  legalName      String?
  website        String?
  email          String?
  phone          String?
  industry       String?
  companySize    String?
  annualRevenue  Decimal?           @db.Decimal(14, 2)
  country        String?
  city           String?
  address        String?
  postcode       String?
  linkedin       String?
  status         CompanyStatus      @default(PROSPECT)
  logo           String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  organisation   Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  leads          Lead[]
  opportunities  Opportunity[]
  notes          CustomerNote[]
  files          CustomerFile[]
  activities     CustomerActivity[]
  tags           CompanyTag[]
  projects       Project[]
  meetings       Meeting[]
  meetingNotes   MeetingNote[]
  invoices       Invoice[]
  quotes         Quote[]
  expenses       Expense[]
  payments       Payment[]
  purchaseOrders PurchaseOrder[]
  subscriptions  Subscription[]
  transactions   Transaction[]
  cashFlowEntries CashFlowEntry[]

  @@index([organisationId, name])
  @@index([organisationId, status])
  @@index([organisationId, industry])
  @@index([organisationId, country])
  @@index([organisationId, city])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model Contact {
  id             String             @id @default(uuid()) @db.Uuid
  organisationId String             @db.Uuid
  companyId      String?            @db.Uuid
  firstName      String
  lastName       String
  email          String?
  phone          String?
  mobile         String?
  jobTitle       String?
  department     String?
  linkedin       String?
  avatar         String?
  birthday       DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  organisation   Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company        Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  activities     CustomerActivity[]
  customerNotes  CustomerNote[]
  files          CustomerFile[]

  @@index([organisationId, companyId])
  @@index([organisationId, email])
  @@index([organisationId, firstName, lastName])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model Lead {
  id                String             @id @default(uuid()) @db.Uuid
  organisationId    String             @db.Uuid
  companyId         String?            @db.Uuid
  assignedTo        String?            @db.Uuid
  source            String?
  status            LeadStatus         @default(NEW)
  probability       Int                @default(0)
  estimatedValue    Decimal?           @db.Decimal(14, 2)
  expectedCloseDate DateTime?
  description       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  organisation      Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignee          User?              @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  activities        CustomerActivity[]

  @@index([organisationId, companyId])
  @@index([organisationId, assignedTo])
  @@index([organisationId, status])
  @@index([organisationId, expectedCloseDate])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model Opportunity {
  id                String             @id @default(uuid()) @db.Uuid
  organisationId    String             @db.Uuid
  companyId         String?            @db.Uuid
  owner             String?            @db.Uuid
  stage             OpportunityStage   @default(DISCOVERY)
  probability       Int                @default(0)
  estimatedRevenue  Decimal?           @db.Decimal(14, 2)
  expectedCloseDate DateTime?
  status            OpportunityStatus  @default(OPEN)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  organisation      Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ownerUser         User?              @relation("OpportunityOwner", fields: [owner], references: [id], onDelete: SetNull)
  activities        CustomerActivity[]

  @@index([organisationId, companyId])
  @@index([organisationId, owner])
  @@index([organisationId, stage])
  @@index([organisationId, status])
  @@index([organisationId, expectedCloseDate])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model CustomerNote {
  id             String       @id @default(uuid()) @db.Uuid
  organisationId String       @db.Uuid
  companyId      String?      @db.Uuid
  contactId      String?      @db.Uuid
  authorId       String?      @db.Uuid
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author         User?        @relation("CustomerNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([organisationId, companyId])
  @@index([organisationId, contactId])
  @@index([organisationId, authorId])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model CustomerFile {
  id               String       @id @default(uuid()) @db.Uuid
  organisationId   String       @db.Uuid
  companyId        String?      @db.Uuid
  contactId        String?      @db.Uuid
  originalFilename String
  storageKey       String
  mimeType         String
  fileSize         Int
  uploadedById     String?      @db.Uuid
  createdAt        DateTime     @default(now())
