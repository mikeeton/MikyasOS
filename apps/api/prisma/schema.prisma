generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  PENDING
  ACTIVE
  SUSPENDED
  DELETED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

enum OrganisationRoleType {
  OWNER
  ADMIN
  MEMBER
  GUEST
  CUSTOM
}

enum CompanyStatus {
  PROSPECT
  ACTIVE
  INACTIVE
  CUSTOMER
  PARTNER
  SUPPLIER
  ARCHIVED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  UNQUALIFIED
  CONVERTED
  LOST
}

enum OpportunityStage {
  DISCOVERY
  QUALIFICATION
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

enum OpportunityStatus {
  OPEN
  WON
  LOST
  ARCHIVED
}

enum CustomerActivityType {
  COMPANY_CREATED
  COMPANY_UPDATED
  CONTACT_ADDED
  LEAD_CREATED
  LEAD_UPDATED
  LEAD_CONVERTED
  OPPORTUNITY_CREATED
  OPPORTUNITY_UPDATED
  OPPORTUNITY_WON
  OPPORTUNITY_LOST
  NOTE_ADDED
  FILE_UPLOADED
  TAG_CHANGED
  CUSTOMER_EDITED
}

enum ProjectStatus {
  PLANNED
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  BLOCKED
  DONE
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum MilestoneStatus {
  PLANNED
  ACTIVE
  COMPLETED
  MISSED
}

enum ProjectActivityType {
  PROJECT_CREATED
  PROJECT_UPDATED
  PROJECT_ARCHIVED
  PROJECT_RESTORED
  TASK_CREATED
  TASK_UPDATED
  TASK_MOVED
  TASK_ASSIGNED
  TASK_COMPLETED
  COMMENT_ADDED
  FILE_UPLOADED
  MILESTONE_UPDATED
  STATUS_CHANGED
  LABEL_CHANGED
  TIME_TRACKED
}

model User {
  id                   String               @id @default(uuid()) @db.Uuid
  email                String               @unique
  name                 String
  passwordHash         String
  status               UserStatus           @default(ACTIVE)
  activeOrganisationId String?              @db.Uuid
  lastLoginAt          DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  deletedAt            DateTime?
  memberships          OrganisationMember[]
  ownedOrganisations   Organisation[]       @relation("OrganisationOwner")
  invitationsSent      Invitation[]         @relation("InvitationInviter")
  invitationsAccepted  Invitation[]         @relation("InvitationAcceptedBy")
  sessions             Session[]
  refreshTokens        RefreshToken[]
  auditLogs            AuditLog[]
  assignedLeads        Lead[]               @relation("LeadAssignee")
  ownedOpportunities   Opportunity[]        @relation("OpportunityOwner")
  customerNotes        CustomerNote[]       @relation("CustomerNoteAuthor")
  customerFiles        CustomerFile[]       @relation("CustomerFileUploader")
  customerActivities   CustomerActivity[]   @relation("CustomerActivityActor")
  ownedProjects        Project[]            @relation("ProjectOwner")
  assignedTasks        Task[]               @relation("TaskAssignee")
  reportedTasks        Task[]               @relation("TaskReporter")
  projectComments      ProjectComment[]     @relation("ProjectCommentAuthor")
  projectFiles         ProjectFile[]        @relation("ProjectFileUploader")
  timeEntries          TimeEntry[]          @relation("TimeEntryUser")
  projectActivities    ProjectActivity[]    @relation("ProjectActivityActor")
  activeOrganisation   Organisation?        @relation("ActiveOrganisation", fields: [activeOrganisationId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([activeOrganisationId])
  @@index([deletedAt])
}

model Organisation {
  id                String               @id @default(uuid()) @db.Uuid
  name              String
  slug              String               @unique
  industry          String?
  companySize       String?
  country           String?
  timezone          String?
  currency          String?
  ownerId           String               @db.Uuid
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  deletedAt         DateTime?
  owner             User                 @relation("OrganisationOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  activeUsers       User[]               @relation("ActiveOrganisation")
  members           OrganisationMember[]
  roles             Role[]
  invitations       Invitation[]
  sessions          Session[]
  refreshTokens     RefreshToken[]
  auditLogs         AuditLog[]
  companies         Company[]
  contacts          Contact[]
  leads             Lead[]
  opportunities     Opportunity[]
  customerNotes     CustomerNote[]
  customerFiles     CustomerFile[]
  customerTags      CustomerTag[]
  activities        CustomerActivity[]
  projects          Project[]
  tasks             Task[]
  projectLabels     ProjectLabel[]
  projectFiles      ProjectFile[]
  timeEntries       TimeEntry[]
  projectBoards     ProjectBoard[]
  projectActivities ProjectActivity[]
  projectComments   ProjectComment[]

  @@index([ownerId])
  @@index([deletedAt])
}

model OrganisationMember {
  id             String               @id @default(uuid()) @db.Uuid
  organisationId String               @db.Uuid
  userId         String               @db.Uuid
  roleId         String               @db.Uuid
  roleType       OrganisationRoleType @default(MEMBER)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  organisation   Organisation         @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  role           Role                 @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([organisationId, userId])
  @@index([userId])
  @@index([roleId])
  @@index([organisationId, roleType])
  @@index([deletedAt])
}

model Role {
  id              String               @id @default(uuid()) @db.Uuid
  organisationId  String               @db.Uuid
  name            String
  description     String?
  type            OrganisationRoleType @default(CUSTOM)
  isSystem        Boolean              @default(false)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
  organisation    Organisation         @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  members         OrganisationMember[]
  rolePermissions RolePermission[]
  invitations     Invitation[]

  @@unique([organisationId, name])
  @@index([organisationId, type])
  @@index([deletedAt])
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  key             String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  createdAt    DateTime   @default(now())
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([permissionId])
}

model Invitation {
  id             String           @id @default(uuid()) @db.Uuid
  organisationId String           @db.Uuid
  email          String
  roleId         String           @db.Uuid
  tokenHash      String           @unique
  status         InvitationStatus @default(PENDING)
  invitedById    String           @db.Uuid
  acceptedById   String?          @db.Uuid
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  revokedAt      DateTime?
  organisation   Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  role           Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)
  invitedBy      User             @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Restrict)
  acceptedBy     User?            @relation("InvitationAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)

  @@unique([organisationId, email, status])
  @@index([organisationId])
  @@index([email])
  @@index([expiresAt])
}

model Session {
  id             String         @id @default(uuid()) @db.Uuid
  userId         String         @db.Uuid
  organisationId String?        @db.Uuid
  userAgent      String?
  ipAddress      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  expiresAt      DateTime
  revokedAt      DateTime?
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation   Organisation?  @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  refreshTokens  RefreshToken[]

  @@index([userId])
  @@index([organisationId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model RefreshToken {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @db.Uuid
  organisationId String?       @db.Uuid
  sessionId      String        @db.Uuid
  tokenHash      String        @unique
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  expiresAt      DateTime
  revokedAt      DateTime?
  replacedById   String?       @unique @db.Uuid
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  organisation   Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  session        Session       @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  replacedBy     RefreshToken? @relation("RefreshTokenRotation", fields: [replacedById], references: [id], onDelete: SetNull)
  replaces       RefreshToken? @relation("RefreshTokenRotation")

  @@index([userId])
  @@index([sessionId])
  @@index([organisationId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model AuditLog {
  id             String        @id @default(uuid()) @db.Uuid
  organisationId String?       @db.Uuid
  actorUserId    String?       @db.Uuid
  action         String
  entityType     String
  entityId       String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime      @default(now())
  organisation   Organisation? @relation(fields: [organisationId], references: [id], onDelete: SetNull)
  actorUser      User?         @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organisationId, createdAt])
  @@index([actorUserId])
  @@index([action])
}

model Company {
  id             String             @id @default(uuid()) @db.Uuid
  organisationId String             @db.Uuid
  name           String
  legalName      String?
  website        String?
  email          String?
  phone          String?
  industry       String?
  companySize    String?
  annualRevenue  Decimal?           @db.Decimal(14, 2)
  country        String?
  city           String?
  address        String?
  postcode       String?
  linkedin       String?
  status         CompanyStatus      @default(PROSPECT)
  logo           String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  organisation   Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  leads          Lead[]
  opportunities  Opportunity[]
  notes          CustomerNote[]
  files          CustomerFile[]
  activities     CustomerActivity[]
  tags           CompanyTag[]
  projects       Project[]

  @@index([organisationId, name])
  @@index([organisationId, status])
  @@index([organisationId, industry])
  @@index([organisationId, country])
  @@index([organisationId, city])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model Contact {
  id             String             @id @default(uuid()) @db.Uuid
  organisationId String             @db.Uuid
  companyId      String?            @db.Uuid
  firstName      String
  lastName       String
  email          String?
  phone          String?
  mobile         String?
  jobTitle       String?
  department     String?
  linkedin       String?
  avatar         String?
  birthday       DateTime?
  notes          String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  organisation   Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company        Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  activities     CustomerActivity[]
  customerNotes  CustomerNote[]
  files          CustomerFile[]

  @@index([organisationId, companyId])
  @@index([organisationId, email])
  @@index([organisationId, firstName, lastName])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model Lead {
  id                String             @id @default(uuid()) @db.Uuid
  organisationId    String             @db.Uuid
  companyId         String?            @db.Uuid
  assignedTo        String?            @db.Uuid
  source            String?
  status            LeadStatus         @default(NEW)
  probability       Int                @default(0)
  estimatedValue    Decimal?           @db.Decimal(14, 2)
  expectedCloseDate DateTime?
  description       String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  organisation      Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  assignee          User?              @relation("LeadAssignee", fields: [assignedTo], references: [id], onDelete: SetNull)
  activities        CustomerActivity[]

  @@index([organisationId, companyId])
  @@index([organisationId, assignedTo])
  @@index([organisationId, status])
  @@index([organisationId, expectedCloseDate])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model Opportunity {
  id                String             @id @default(uuid()) @db.Uuid
  organisationId    String             @db.Uuid
  companyId         String?            @db.Uuid
  owner             String?            @db.Uuid
  stage             OpportunityStage   @default(DISCOVERY)
  probability       Int                @default(0)
  estimatedRevenue  Decimal?           @db.Decimal(14, 2)
  expectedCloseDate DateTime?
  status            OpportunityStatus  @default(OPEN)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  deletedAt         DateTime?
  organisation      Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company           Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  ownerUser         User?              @relation("OpportunityOwner", fields: [owner], references: [id], onDelete: SetNull)
  activities        CustomerActivity[]

  @@index([organisationId, companyId])
  @@index([organisationId, owner])
  @@index([organisationId, stage])
  @@index([organisationId, status])
  @@index([organisationId, expectedCloseDate])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model CustomerNote {
  id             String       @id @default(uuid()) @db.Uuid
  organisationId String       @db.Uuid
  companyId      String?      @db.Uuid
  contactId      String?      @db.Uuid
  authorId       String?      @db.Uuid
  content        String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company        Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact        Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  author         User?        @relation("CustomerNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)

  @@index([organisationId, companyId])
  @@index([organisationId, contactId])
  @@index([organisationId, authorId])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model CustomerFile {
  id               String       @id @default(uuid()) @db.Uuid
  organisationId   String       @db.Uuid
  companyId        String?      @db.Uuid
  contactId        String?      @db.Uuid
  originalFilename String
  storageKey       String
  mimeType         String
  fileSize         Int
  uploadedById     String?      @db.Uuid
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  deletedAt        DateTime?
  organisation     Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company          Company?     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact          Contact?     @relation(fields: [contactId], references: [id], onDelete: Cascade)
  uploadedBy       User?        @relation("CustomerFileUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@unique([organisationId, storageKey])
  @@index([organisationId, companyId])
  @@index([organisationId, contactId])
  @@index([organisationId, uploadedById])
  @@index([organisationId, mimeType])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model CustomerActivity {
  id             String               @id @default(uuid()) @db.Uuid
  organisationId String               @db.Uuid
  companyId      String?              @db.Uuid
  contactId      String?              @db.Uuid
  leadId         String?              @db.Uuid
  opportunityId  String?              @db.Uuid
  actorUserId    String?              @db.Uuid
  type           CustomerActivityType
  title          String
  description    String?
  metadata       Json?
  createdAt      DateTime             @default(now())
  organisation   Organisation         @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company        Company?             @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact        Contact?             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lead           Lead?                @relation(fields: [leadId], references: [id], onDelete: Cascade)
  opportunity    Opportunity?         @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  actorUser      User?                @relation("CustomerActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organisationId, companyId, createdAt])
  @@index([organisationId, contactId, createdAt])
  @@index([organisationId, leadId, createdAt])
  @@index([organisationId, opportunityId, createdAt])
  @@index([organisationId, type])
  @@index([organisationId, createdAt])
}

model CustomerTag {
  id             String       @id @default(uuid()) @db.Uuid
  organisationId String       @db.Uuid
  name           String
  color          String       @default("#111827")
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  companies      CompanyTag[]

  @@unique([organisationId, name])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model CompanyTag {
  id        String      @id @default(uuid()) @db.Uuid
  companyId String      @db.Uuid
  tagId     String      @db.Uuid
  createdAt DateTime    @default(now())
  company   Company     @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag       CustomerTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([companyId, tagId])
  @@index([tagId])
}

model Project {
  id             String             @id @default(uuid()) @db.Uuid
  organisationId String             @db.Uuid
  companyId      String?            @db.Uuid
  ownerId        String             @db.Uuid
  name           String
  description    String?
  status         ProjectStatus      @default(PLANNED)
  priority       ProjectPriority    @default(MEDIUM)
  progress       Int                @default(0)
  budget         Decimal?           @db.Decimal(14, 2)
  estimatedHours Decimal?           @db.Decimal(10, 2)
  actualHours    Decimal?           @db.Decimal(10, 2)
  startDate      DateTime?
  dueDate        DateTime?
  completedAt    DateTime?
  archivedAt     DateTime?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  deletedAt      DateTime?
  organisation   Organisation       @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  company        Company?           @relation(fields: [companyId], references: [id], onDelete: SetNull)
  owner          User               @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  tasks          Task[]
  milestones     ProjectMilestone[]
  comments       ProjectComment[]
  files          ProjectFile[]
  boards         ProjectBoard[]
  activities     ProjectActivity[]

  @@index([organisationId, name])
  @@index([organisationId, companyId])
  @@index([organisationId, ownerId])
  @@index([organisationId, status])
  @@index([organisationId, priority])
  @@index([organisationId, dueDate])
  @@index([organisationId, archivedAt])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model Task {
  id             String            @id @default(uuid()) @db.Uuid
  organisationId String            @db.Uuid
  projectId      String            @db.Uuid
  parentTaskId   String?           @db.Uuid
  title          String
  description    String?
  status         TaskStatus        @default(TODO)
  priority       TaskPriority      @default(MEDIUM)
  assigneeId     String?           @db.Uuid
  reporterId     String?           @db.Uuid
  estimatedHours Decimal?          @db.Decimal(10, 2)
  actualHours    Decimal?          @db.Decimal(10, 2)
  dueDate        DateTime?
  position       Int               @default(0)
  completedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  deletedAt      DateTime?
  organisation   Organisation      @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  project        Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parentTask     Task?             @relation("TaskSubtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks       Task[]            @relation("TaskSubtasks")
  assignee       User?             @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  reporter       User?             @relation("TaskReporter", fields: [reporterId], references: [id], onDelete: SetNull)
  comments       ProjectComment[]
  files          ProjectFile[]
  labels         TaskLabel[]
  timeEntries    TimeEntry[]
  activities     ProjectActivity[]

  @@index([organisationId, projectId])
  @@index([organisationId, parentTaskId])
  @@index([organisationId, assigneeId])
  @@index([organisationId, reporterId])
  @@index([organisationId, status])
  @@index([organisationId, priority])
  @@index([organisationId, dueDate])
  @@index([organisationId, position])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model ProjectMilestone {
  id          String            @id @default(uuid()) @db.Uuid
  projectId   String            @db.Uuid
  title       String
  description String?
  dueDate     DateTime?
  status      MilestoneStatus   @default(PLANNED)
  progress    Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  deletedAt   DateTime?
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  activities  ProjectActivity[]

  @@index([projectId, status])
  @@index([projectId, dueDate])
  @@index([projectId, deletedAt])
}

model ProjectLabel {
  id             String       @id @default(uuid()) @db.Uuid
  organisationId String       @db.Uuid
  name           String
  colour         String       @default("#111827")
  icon           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  organisation   Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  tasks          TaskLabel[]

  @@unique([organisationId, name])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model TaskLabel {
  id        String       @id @default(uuid()) @db.Uuid
  taskId    String       @db.Uuid
  labelId   String       @db.Uuid
  createdAt DateTime     @default(now())
  task      Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  label     ProjectLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([taskId, labelId])
  @@index([labelId])
}

model ProjectComment {
  id              String           @id @default(uuid()) @db.Uuid
  organisationId  String           @db.Uuid
  projectId       String           @db.Uuid
  taskId          String?          @db.Uuid
  parentCommentId String?          @db.Uuid
  authorId        String?          @db.Uuid
  content         String
  mentions        Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?
  organisation    Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  project         Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task            Task?            @relation(fields: [taskId], references: [id], onDelete: Cascade)
  parentComment   ProjectComment?  @relation("ProjectCommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies         ProjectComment[] @relation("ProjectCommentReplies")
  author          User?            @relation("ProjectCommentAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  files           ProjectFile[]

  @@index([organisationId, projectId, createdAt])
  @@index([organisationId, taskId, createdAt])
  @@index([organisationId, parentCommentId])
  @@index([organisationId, authorId])
  @@index([organisationId, deletedAt])
}

model ProjectFile {
  id               String          @id @default(uuid()) @db.Uuid
  organisationId   String          @db.Uuid
  projectId        String          @db.Uuid
  taskId           String?         @db.Uuid
  commentId        String?         @db.Uuid
  storageKey       String
  originalFilename String
  mimeType         String
  fileSize         Int
  uploadedById     String?         @db.Uuid
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  deletedAt        DateTime?
  organisation     Organisation    @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  project          Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task             Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  comment          ProjectComment? @relation(fields: [commentId], references: [id], onDelete: SetNull)
  uploadedBy       User?           @relation("ProjectFileUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  @@unique([organisationId, storageKey])
  @@index([organisationId, projectId])
  @@index([organisationId, taskId])
  @@index([organisationId, commentId])
  @@index([organisationId, uploadedById])
  @@index([organisationId, mimeType])
  @@index([organisationId, deletedAt])
  @@index([organisationId, createdAt])
}

model TimeEntry {
  id              String       @id @default(uuid()) @db.Uuid
  organisationId  String       @db.Uuid
  taskId          String       @db.Uuid
  userId          String       @db.Uuid
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  manualEntry     Boolean      @default(false)
  description     String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  deletedAt       DateTime?
  organisation    Organisation @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  task            Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user            User         @relation("TimeEntryUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organisationId, taskId])
  @@index([organisationId, userId])
  @@index([organisationId, startTime])
  @@index([organisationId, deletedAt])
}

model ProjectBoard {
  id             String               @id @default(uuid()) @db.Uuid
  organisationId String               @db.Uuid
  projectId      String               @db.Uuid
  name           String
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  deletedAt      DateTime?
  organisation   Organisation         @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  project        Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns        ProjectBoardColumn[]

  @@unique([projectId, name])
  @@index([organisationId, projectId])
  @@index([organisationId, deletedAt])
}

model ProjectBoardColumn {
  id        String       @id @default(uuid()) @db.Uuid
  boardId   String       @db.Uuid
  name      String
  status    TaskStatus?
  position  Int          @default(0)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  board     ProjectBoard @relation(fields: [boardId], references: [id], onDelete: Cascade)

  @@index([boardId, position])
}

model ProjectActivity {
  id             String              @id @default(uuid()) @db.Uuid
  organisationId String              @db.Uuid
  projectId      String              @db.Uuid
  taskId         String?             @db.Uuid
  milestoneId    String?             @db.Uuid
  actorUserId    String?             @db.Uuid
  type           ProjectActivityType
  title          String
  description    String?
  metadata       Json?
  createdAt      DateTime            @default(now())
  organisation   Organisation        @relation(fields: [organisationId], references: [id], onDelete: Cascade)
  project        Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task           Task?               @relation(fields: [taskId], references: [id], onDelete: Cascade)
  milestone      ProjectMilestone?   @relation(fields: [milestoneId], references: [id], onDelete: Cascade)
  actorUser      User?               @relation("ProjectActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([organisationId, projectId, createdAt])
  @@index([organisationId, taskId, createdAt])
  @@index([organisationId, milestoneId, createdAt])
  @@index([organisationId, actorUserId])
  @@index([organisationId, type])
  @@index([organisationId, createdAt])
}
